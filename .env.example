# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Arbitrum Sepolia RPC used by the frontend to wait for mint transaction receipts.
VITE_ARBITRUM_SEPOLIA_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"

# Deployed CuberAchievementNFT contract address on Arbitrum Sepolia.
VITE_CUBER_NFT_CONTRACT="0xYourArbitrumSepoliaContractAddress"

# Backend endpoint that returns { request, signature } for mintWithSignature.
VITE_CUBER_SIGNATURE_API="http://localhost:8080/api/contracts/cuber-achievement/mint-request"
VITE_CUBER_REVIEW_SYNC_API="http://localhost:8080/api/contracts/cuber-achievement/reviews"

# Backend signer API settings.
MINT_SIGNATURE_API_HOST="127.0.0.1"
MINT_SIGNATURE_API_PORT="8080"
MINT_SIGNATURE_ALLOWED_ORIGIN="http://localhost:3000"
SIGNER_PRIVATE_KEY="0xYourBackendSignerPrivateKey"
CUBER_NFT_CONTRACT="0xYourArbitrumSepoliaContractAddress"
CUBER_METADATA_BASE_URI="https://metadata.moledao.io/achievements/"
